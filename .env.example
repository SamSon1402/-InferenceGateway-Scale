# Queue backend: 'redis' (production) or 'memory' (no Redis dependency, single-process only)
QUEUE_BACKEND=redis
REDIS_URL=redis://localhost:6379
QUEUE_NAMESPACE=iqs

# Provider API keys — at least one must be set
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Worker pool bounds
MIN_WORKERS=1
MAX_WORKERS=8
INITIAL_WORKERS=2

# Autoscaler (HPA-style proportional)
AUTOSCALER_INTERVAL_S=5
TARGET_QUEUE_PER_WORKER=10
SCALE_UP_COOLDOWN_S=30
SCALE_DOWN_COOLDOWN_S=60

# Per-provider token-bucket limits (capacity / refill-per-second)
OPENAI_CAPACITY=10000
OPENAI_REFILL_PER_S=167
ANTHROPIC_CAPACITY=8000
ANTHROPIC_REFILL_PER_S=133
MISTRAL_CAPACITY=12000
MISTRAL_REFILL_PER_S=200

# Retry policy
RETRY_MAX_ATTEMPTS=4
RETRY_INITIAL_BACKOFF_S=0.5
RETRY_MAX_BACKOFF_S=8

# Sync timeout for /v1/completions
SYNC_TIMEOUT_S=30

LOG_LEVEL=INFO
